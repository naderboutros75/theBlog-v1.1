<%- include('./partials/header') %>
    <h1>Compose</h1>
    <div>
        <form action="/compose" method="post" class="">
            <div class="mb-3">
                <label for="postTitle" class="form-label">Title</label>
                <input type="text" name="postTitle" class="form-control" id="postTitle" />
            </div>
            <div class="mb-3">
                <label for="postBody" class="form-label">Post</label>
                <textarea name="postBody" class="form-control" id="postBody" rows="5"></textarea>
            </div>
            <button type="submit" class="btn btn-primary mb-3">
                Publish
            </button>
        </form>
    </div>
    <%- include('./partials/footer') %>